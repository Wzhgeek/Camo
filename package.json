    "@tauri-apps/plugin-opener": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.4",
    "pinia": "^3.0.4",
    "sql.js": "^1.14.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
