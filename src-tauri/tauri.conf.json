{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Camo",
  "version": "0.2.9",
  "identifier": "com.camo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Camo",
        "width": 180,
        "height": 210,
        "minWidth": 90,
        "minHeight": 105,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "backgroundColor": [0, 0, 0, 0]
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/Wzhgeek/Camo/releases/latest/download/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEwQTk4MkY3MDZDMjgxQzQKUldURWdjSUc5NEtwRU93dVp6eThwclVFV2F4emZod2c1aVFTYk56ZTY5QnF3Q3lRVFN3NVdPMVUK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
