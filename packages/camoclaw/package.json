{
  "name": "camoclaw",
  "version": "0.1.0",
  "description": "Agent loop, skill system, and tool calling for LLM-powered desktop assistants. Framework-agnostic core.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./skill": {
      "types": "./dist/skill/index.d.ts",
      "import": "./dist/skill/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "llm",
    "agent",
    "tool-calling",
    "skill",
    "desktop-assistant"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wzhgeek/Camo.git",
    "directory": "packages/camoclaw"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.0"
  }
}
