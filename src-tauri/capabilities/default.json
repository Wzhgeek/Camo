{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for Camo pet and tool windows",
  "windows": ["main", "chat", "settings", "reminders", "reminder-alert", "reminder-alert-1", "reminder-alert-2", "reminder-alert-3", "context-menu"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-set-size-constraints",
    "core:window:allow-set-visible-on-all-workspaces",
    "core:window:allow-outer-position",
    "core:window:allow-outer-size",
    "core:window:allow-current-monitor",
    "core:window:allow-primary-monitor",
    "core:window:allow-available-monitors",
    "core:window:allow-start-dragging",
    "opener:default"
  ]
}
